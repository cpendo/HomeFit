# Server
PORT=5000
NODE_ENV=development
SESSION_SECRET=change-me-to-a-random-string
JWT_SECRET=change-me-to-another-random-string
FRONTEND_URL=http://localhost:5173

# Database — defaults to SQLite (file in backend/data.sqlite)
# Set DB_DIALECT=mysql to use legacy MySQL config below.
DB_DIALECT=sqlite
# SQLITE_PATH=/data/homefit.sqlite  # override storage path (e.g. Fly.io volume)

# Legacy MySQL (only used when DB_DIALECT=mysql)
DB_NAME=homefit
DB_USERNAME=root
DB_PASSWORD=
DB_HOST=localhost

# Demo mode: auto-verify new accounts, skip email sending entirely.
# Set DEMO_MODE=true on portfolio deploys so recruiters don't need an inbox.
DEMO_MODE=false

# Email (used when DEMO_MODE=false)
GMAIL_ACCOUNT=
GMAIL_PASSWORD=

# YouTube (used by the YouTube search proxy)
YOUTUBE_API_KEY=
